{
  "name": "adalah-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm run dev -w @adalah/api",
    "dev:web": "npm run dev -w @adalah/web",
    "dev:all": "npm run dev:api & npm run dev:web",
    "build": "npm run build -w @adalah/sdk && npm run build -w @adalah/api && npm run build -w @adalah/web",
    "build:api": "npm run build -w @adalah/api",
    "build:web": "npm run build -w @adalah/web",
    "build:sdk": "npm run build -w @adalah/sdk",
    "test": "npm run test -w @adalah/api && npm run test -w @adalah/sdk",
    "test:e2e": "npm run test:e2e -w @adalah/web",
    "staging:up": "docker compose -f docker-compose.staging.yml --env-file .env.staging up -d --build",
    "staging:down": "docker compose -f docker-compose.staging.yml --env-file .env.staging down",
    "staging:smoke": "node scripts/staging-smoke.mjs",
    "staging:logs": "docker compose -f docker-compose.staging.yml --env-file .env.staging logs -f",
    "prod:up": "./scripts/deploy-prod.sh",
    "prod:cutover": "./scripts/cutover-adalahai.sh",
    "verify:dns": "./scripts/verify-dns.sh",
    "prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.prod down",
    "prod:smoke": "node scripts/production-smoke.mjs",
    "prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.prod logs -f",
    "openai:smoke": "node scripts/openai-smoke.mjs",
    "lint": "npm run lint -w @adalah/api && npm run lint -w @adalah/web && npm run lint -w @adalah/sdk",
    "db:generate": "npm run db:generate -w @adalah/api",
    "db:migrate": "npm run db:migrate -w @adalah/api",
    "db:seed": "npm run db:seed -w @adalah/api",
    "db:studio": "npm run db:studio -w @adalah/api"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
