# Production environment — copy to .env.prod and fill values
# Deploy: ./scripts/deploy-prod.sh

POSTGRES_USER=adalah
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=adalah

JWT_SECRET=change-me-to-random-64-char-string-in-production-minimum-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# --- Domain & HTTPS (set for production with Caddy) ---
# Leave DOMAIN empty for local/direct-ports mode
DOMAIN=
WEB_DOMAIN=
API_DOMAIN=
ACME_EMAIL=admin@your-domain.com

# Public URLs (must match domain setup)
NEXT_PUBLIC_API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000

# Example with domain (see .env.prod.adalahai.example for adalahai.com):
# DOMAIN=adalahai.com
# WEB_DOMAIN=adalah.example.com
# API_DOMAIN=api.adalah.example.com
# ACME_EMAIL=admin@adalah.example.com
# NEXT_PUBLIC_API_URL=https://api.adalah.example.com
# CORS_ORIGINS=https://adalah.example.com

# --- AI ---
LLM_PROVIDER=openai
EMBEDDER_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2
EMBEDDING_DIMENSIONS=384

METRICS_ENABLED=true

# Direct ports (used when DOMAIN is empty)
API_PORT=3001
WEB_PORT=3000
