# Staging environment — copy to .env.staging and adjust values
# Used with: docker compose -f docker-compose.staging.yml --env-file .env.staging up -d --build

POSTGRES_USER=adalah
POSTGRES_PASSWORD=staging-change-me-strong-password
POSTGRES_DB=adalah_staging

JWT_SECRET=staging-jwt-secret-minimum-32-characters-long-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# AI — mock by default on staging; set openai for live integration tests
LLM_PROVIDER=mock
EMBEDDER_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384

# Optional: enable OpenAI on staging
# LLM_PROVIDER=openai
# EMBEDDER_PROVIDER=openai
# OPENAI_API_KEY=sk-...

METRICS_ENABLED=true

API_PORT=3001
WEB_PORT=3000

# Public API URL as seen by the browser
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: OpenAI smoke test in CI (set as GitHub secret)
# OPENAI_API_KEY=sk-...
