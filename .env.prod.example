# Production environment — copy to .env.prod and fill values
POSTGRES_USER=adalah
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=adalah

JWT_SECRET=change-me-to-random-64-char-string-in-production-minimum-32

# AI — switch to openai for production
LLM_PROVIDER=mock
EMBEDDER_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2
EMBEDDING_DIMENSIONS=384

# Monitoring
METRICS_ENABLED=true

API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
